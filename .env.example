# ── Postgres ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://topup:topup@localhost:5432/topup

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_access_secret_32_chars_min
JWT_REFRESH_SECRET=change_me_refresh_secret_32_chars_min

# ── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── KHQR / Bakong ────────────────────────────────────────────────────────────
KHQR_MERCHANT_ID=000000000000000
KHQR_BAKONG_TOKEN=dev_stub_token

# ── Bank redirect ────────────────────────────────────────────────────────────
BANK_RETURN_URL=http://localhost:3000/checkout/return

# ── Origins ──────────────────────────────────────────────────────────────────
WEB_ORIGIN=http://localhost:3000
API_ORIGIN=http://localhost:4000

# ── Node environment ─────────────────────────────────────────────────────────
NODE_ENV=development
